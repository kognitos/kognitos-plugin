# Kognitos environment variables
# Copy to .env.local and fill in your values.

# Required — Personal Access Token from the Kognitos console (prefix: kgn_pat_)
KOGNITOS_TOKEN=

# Region: us, eu, uk (default: us)
KOGNITOS_REGION=us

# Environment: prod, dev (default: prod)
KOGNITOS_ENV=dev

# Organization and workspace IDs — discover these by listing orgs/workspaces
# with curl or the bootstrap skill after setting the token above.
KOGNITOS_ORGANIZATION_ID=
KOGNITOS_WORKSPACE_ID=
